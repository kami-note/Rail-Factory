# Rail Factory — Environment variables for Docker Compose and services
# Copy to .env and adjust. Do not commit .env with real secrets.

# PostgreSQL (default tenant DB for dev)
POSTGRES_USER=railfactory
POSTGRES_PASSWORD=railfactory_secret
POSTGRES_DB=railfactory_tenant_default
POSTGRES_PORT=5432

# Connection string template for apps: Host=localhost;Port=5432;Database=railfactory_tenant_{TenantId};Username=railfactory;Password=...
# Tenant resolution (Phase 1+) will map TenantId to connection string; one DB per tenant.

# Redis (shared; use key prefix per tenant/service, e.g. tenant:{id}:service:key)
REDIS_PORT=6379
REDIS_CONNECTION=localhost:6379

# RabbitMQ (MassTransit)
RABBITMQ_USER=railfactory
RABBITMQ_PASSWORD=railfactory_secret
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_HOST=localhost
# Full URL for apps: amqp://railfactory:railfactory_secret@localhost:5672/

# Gateway (Nginx) — reverse proxy; routes /api/<service>/ to backends
GATEWAY_PORT=80
# Backend ports (when running services with dotnet run; use --urls http://localhost:PORT)
# IAM=5243, Production=5244, Dashboard=5245, SupplyChain=5246, Logistics=5247, Fleet=5248, HCM=5249
