@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="min-h-dvh bg-slate-50">
    <div class="mx-auto max-w-7xl px-4 py-6 lg:flex lg:gap-8">
        <aside class="mb-6 lg:mb-0 lg:w-64">
            <NavMenu />
        </aside>

        <main class="min-w-0 flex-1">
            <header class="mb-6 flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-5 py-4 shadow-sm">
                <div>
                    <div class="text-sm font-medium text-slate-500">Rail Factory</div>
                    <div class="text-lg font-semibold tracking-tight">Dev Console</div>
                </div>

                <AuthorizeView>
                    <Authorized>
                        <div class="text-right">
                            <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">Signed in</div>
                            <div class="text-sm text-slate-900">@context.User.Identity?.Name</div>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <div class="text-right">
                            <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">Session</div>
                            <div class="text-sm text-slate-700">Anonymous</div>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </header>

            <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                @Body
            </article>
        </main>
    </div>
</div>

<div id="blazor-error-ui" class="fixed inset-x-0 bottom-0 hidden border-t border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-100" data-nosnippet>
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-4">
        <div>
            An unhandled error has occurred.
            <a href="." class="ml-2 underline">Reload</a>
        </div>
        <button class="dismiss rounded-lg px-2 py-1 text-amber-100/80 hover:text-amber-50" type="button">Dismiss</button>
    </div>
</div>
