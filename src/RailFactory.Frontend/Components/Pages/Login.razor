@page "/login"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout RailFactory.Frontend.Components.Layout.AuthLayout
@rendermode InteractiveServer

@using RailFactory.Frontend.Security

<PageTitle>Login</PageTitle>

<div class="mx-auto max-w-md">
    <h1 class="mb-2 text-2xl font-semibold tracking-tight text-slate-900">Sign in</h1>
    <p class="mb-6 text-sm text-slate-600">
        Dev-only login for now. This will be replaced by IAM integration.
    </p>

    <UiCard Class="space-y-4">
        <div class="text-sm text-slate-700">
            Authentication is handled by IAM via Google OAuth.
        </div>

        <a href="/auth/google"
           class="inline-flex w-full items-center justify-center rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500">
            Continue with Google
        </a>

        <div class="text-xs text-slate-500">
            After Google sign-in, you will be redirected to <span class="font-mono">/auth/callback</span>.
        </div>
    </UiCard>
</div>

