@page "/register"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout RailFactory.Frontend.Components.Layout.AuthLayout
@rendermode InteractiveServer

@using RailFactory.Frontend.Security

<PageTitle>Register</PageTitle>

<div class="mx-auto max-w-md">
    <h1 class="mb-2 text-2xl font-semibold tracking-tight text-slate-900">Create account</h1>
    <p class="mb-6 text-sm text-slate-600">
        Dev-only registration for now. This will be replaced by IAM integration.
    </p>

    <UiCard Class="space-y-4">
        <div class="text-sm text-slate-700">
            Account provisioning is handled by IAM via Google OAuth.
        </div>

        <a href="/auth/google"
           class="inline-flex w-full items-center justify-center rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500">
            Continue with Google
        </a>

        <div class="flex items-center justify-end">
            <a class="text-sm text-slate-600 underline decoration-slate-300 underline-offset-4 hover:text-slate-900"
               href="/login">
                Back to login
            </a>
        </div>
    </UiCard>
</div>

