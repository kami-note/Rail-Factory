@namespace RailFactory.Frontend.Components.Ui

@if (!string.IsNullOrWhiteSpace(Message))
{
    <div class="@CssClass" role="alert">
        @Message
    </div>
}

@code {
    public enum AlertKind
    {
        Info,
        Danger
    }

    [Parameter] public string? Message { get; set; }
    [Parameter] public AlertKind Kind { get; set; } = AlertKind.Info;
    [Parameter] public string? Class { get; set; }

    private string CssClass
    {
        get
        {
            var baseClass = "rounded-xl border px-3 py-2 text-sm";
            var kindClass = Kind switch
            {
                AlertKind.Info => "border-slate-200 bg-slate-50 text-slate-700",
                AlertKind.Danger => "border-rose-200 bg-rose-50 text-rose-700",
                _ => "border-slate-200 bg-slate-50 text-slate-700"
            };

            return string.IsNullOrWhiteSpace(Class)
                ? $"{baseClass} {kindClass}"
                : $"{baseClass} {kindClass} {Class}";
        }
    }
}

