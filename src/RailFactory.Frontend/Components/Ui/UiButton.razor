@namespace RailFactory.Frontend.Components.Ui

<button type="@Type"
        disabled="@Disabled"
        class="@CssClass"
        @attributes="AdditionalAttributes">
    @ChildContent
</button>

@code {
    public enum ButtonVariant
    {
        Primary,
        Ghost
    }

    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public ButtonVariant Variant { get; set; } = ButtonVariant.Primary;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass
    {
        get
        {
            var baseClass = "inline-flex items-center justify-center rounded-xl px-4 py-2 text-sm font-semibold shadow-sm disabled:opacity-60";
            var variantClass = Variant switch
            {
                ButtonVariant.Primary => "bg-indigo-600 text-white hover:bg-indigo-500",
                ButtonVariant.Ghost => "bg-transparent text-slate-700 hover:bg-slate-100",
                _ => "bg-indigo-600 text-white hover:bg-indigo-500"
            };
            return string.IsNullOrWhiteSpace(Class)
                ? $"{baseClass} {variantClass}"
                : $"{baseClass} {variantClass} {Class}";
        }
    }
}

