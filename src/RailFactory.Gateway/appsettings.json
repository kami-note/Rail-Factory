{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "iam-auth": {
        "ClusterId": "iam-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "iam-api": {
        "ClusterId": "iam-cluster",
        "Match": {
          "Path": "/api/iam/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      },
      "iam-swagger": {
        "ClusterId": "iam-cluster",
        "Match": {
          "Path": "/swagger/iam/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      },
      "iam-health": {
        "ClusterId": "iam-cluster",
        "Match": {
          "Path": "/health/iam"
        },
        "Transforms": [
          { "PathSet": "/health" }
        ]
      }
    },
    "Clusters": {
      "iam-cluster": {
        "Destinations": {
          "iam": {
            "Address": "http://identity-access-management"
          }
        },
        "HttpClient": {
          "RequestTimeout": "00:00:30"
        },
        "LoadBalancingPolicy": "PowerOfTwoChoices",
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:01:00"
          }
        }
      }
    }
  }
}
